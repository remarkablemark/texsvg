{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmit": true,
    "allowJs": true,
    "isolatedModules": true,
    "rootDir": ".",
    "types": ["jest", "node", "yargs"]
  },
  "include": ["__tests__", "src", "eslint.config.mts", "jest.config.ts"]
}
