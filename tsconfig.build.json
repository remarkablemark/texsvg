{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["dom", "es2015"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "strict": true,
    "removeComments": true,
    "rootDir": "src",
    "outDir": "cjs",
    "types": ["node", "yargs"]
  },
  "include": ["src"]
}
